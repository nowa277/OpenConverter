dist/*.ncm
dist/test-ncm/
tests/ncm_format/
tests/errors/
tests/*.log

# Original DMG / extracted source (reversing artifacts, never commit)
*.dmg
*.pkg
*.img
extracted/
build/original-app/
build/*.img

# Documentation (internal planning/spec/notes — not part of the shipped project)
docs/

# Previous work / leftover scaffolding
.junk/
app.asar
app.asar.unpacked/

