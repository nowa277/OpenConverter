# Node
node_modules/
package-lock.json

# Build outputs (regeneratable)
dist-renderer/
release/
out/
tests/output/

# Test data: encrypted audio samples (120MB+ copyrighted, gitignored)
# Put your own .ncm / .qmc / .kgm / .kwm files in dist/test-ncm/ to run tests.
dist/*.ncm
dist/test-ncm/
tests/ncm_format/
tests/errors/
tests/*.log

# Original DMG / extracted source (reversing artifacts, never commit)
*.dmg
*.pkg
*.img
extracted/
build/original-app/
build/*.img

# Documentation / reference notes (non-substantive)
# Allow design specs (superpowers/brainstorming outputs)
docs/*
!docs/superpowers/
!docs/superpowers/**

# Previous work / leftover scaffolding
.junk/
app.asar
app.asar.unpacked/

# Local tooling config
.claude/
.codegraph/
.mcp.json
.omc/
opencode.jsonc
data/
gpt-image2-output/
AGENTS.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary outputs
*.raw
*.bak

# Editor backups
*.tmp

# Windows build artifacts (downloaded by scripts/setup-win-deps.sh, not committed)
scripts/win-deps/

# Generated Windows icon (created by ImageMagick during setup-win-deps.sh)
build/icons/*.ico

# Local user artifacts (test screenshots, scratch output)
errors_screenshots/

# Android build outputs (regeneratable, large)
android/.gradle/
android/app/build/
android/build/
android/local.properties
# ffmpeg shared libraries built by android/scripts/build-ffmpeg.sh.
# 7 .so files per ABI (libavformat, libavcodec, libavutil, libswresample,
# libswscale, libavfilter, libavdevice) = ~7.5 MB per ABI. Build locally
# before assembling APKs; do not commit.
android/app/src/main/jniLibs/*/libav*.so
android/app/src/main/jniLibs/*/libsw*.so
android/app/src/main/jniLibs/*/*.so.debug

# Android signing keys
*.jks
*.keystore

# Android release artifacts
release/openconverter-v*.apk